#!/bin/bash
# jvm-run <ver> <cmd> [args...] — PURE docker mechanics, NO Java knowledge.
# Runs the single ALL-JDK image with JAVA_HOME pinned to <ver> (the scorer's bytecode gate enforces the
# real target, so one shared all-JDK env is safe and avoids toolchain-resolution chicken-and-egg).
set -uo pipefail
VER="$1"; shift
: "${BJV_WS:?BJV_WS (host workspace path) must be set}"
MOUNTS=()
[ -d "${BJV_M2:-}" ]           && MOUNTS+=(-v "${BJV_M2}:/root/.m2")
[ -f "${BJV_SETTINGS:-}" ]     && MOUNTS+=(-v "${BJV_SETTINGS}:/root/.m2/settings.xml:ro")
[ -d "${BJV_GRADLE_RO:-}" ]    && MOUNTS+=(-v "${BJV_GRADLE_RO}:/ro:ro")
[ -d "${BJV_GRADLE_DISTS:-}" ] && MOUNTS+=(-v "${BJV_GRADLE_DISTS}:/dists")
exec timeout -k 60 "${BJV_HANG_GUARD:-5400}" docker run --rm --network "${BJV_NET:-mvn-cache}" -e HOME=/root -e BJV_JDK="$VER" \
  -v "$BJV_WS:/work" -w /work "${MOUNTS[@]}" bjv-alljdk "$@"
