# Single ALL-JDK execution image for v2 (JDKs 8/11/17/21/25 + mvn + gradle, from bump-allagents-sweep)
# + offline OSV scanner/DB + jvmjob. Safe as one shared env because the scorer's bytecode gate enforces
# the real target; the env no longer needs to be the forcing function.
FROM bump-allagents-sweep:latest
COPY osv-scanner /usr/local/bin/osv-scanner
COPY osv-db/ /root/.cache/osv-scanner/
COPY jvmjob /usr/local/bin/jvmjob
RUN chmod +x /usr/local/bin/osv-scanner /usr/local/bin/jvmjob
WORKDIR /work
