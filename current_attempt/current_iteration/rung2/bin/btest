#!/bin/bash
exec 0</dev/null   # any command that reads stdin gets EOF, never blocks the terminal (root-fix for stdin hangs)
# Run tests under a chosen JDK. Usage: btest <8|11>
V=${1:?usage: btest <8|11>}
if [ -f pom.xml ]; then exec env JAVA_HOME=/opt/jdk/$V mvn -B -ntp test -Dmaven.test.failure.ignore=true
elif [ -x ./gradlew ]; then exec env JAVA_HOME=/opt/jdk/$V GRADLE_OPTS=-Xmx6g ./gradlew --no-daemon test --continue
else exec env JAVA_HOME=/opt/jdk/$V GRADLE_OPTS=-Xmx6g gradle --no-daemon test --continue; fi
