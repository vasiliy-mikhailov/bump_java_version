#!/bin/bash
exec 0</dev/null   # any command that reads stdin gets EOF, never blocks the terminal (root-fix for stdin hangs)
# Compile (no tests) under a chosen JDK. Usage: bbuild <8|11>
V=${1:?usage: bbuild <8|11>}
if [ -f pom.xml ]; then exec env JAVA_HOME=/opt/jdk/$V mvn -B -ntp -DskipTests test-compile
elif [ -x ./gradlew ]; then exec env JAVA_HOME=/opt/jdk/$V GRADLE_OPTS=-Xmx6g ./gradlew --no-daemon testClasses
else exec env JAVA_HOME=/opt/jdk/$V GRADLE_OPTS=-Xmx6g gradle --no-daemon testClasses; fi
