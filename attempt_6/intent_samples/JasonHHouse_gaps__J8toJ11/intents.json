      {
        "general_idea": "Update the Java source and target compatibility version from 1.8 to 11 to align with the JDK 11 migration.",
        "why_exists": "The project is migrating to JDK 11; keeping java.version at 1.8 would cause compilation failures or runtime incompatibilities with JDK 11-specific APIs or module system expectations.",
        "before": "<java.version>1.8</java.version>",
        "after": "<java.version>11</java.version>",
        "kind": "update_java_version",
        "bucket": "breaking"
      },
      {
        "general_idea": "Upgrade the Spring Boot parent version from 2.1.2.RELEASE to 2.2.6.RELEASE to support JDK 11.",
        "why_exists": "Spring Boot 2.1.x has limited or no support for JDK 11; upgrading to 2.2.x is required for proper compilation and runtime behavior on JDK 11.",
        "before": "<version>2.1.2.RELEASE</version>",
        "after": "<version>2.2.6.RELEASE</version>",
        "kind": "upgrade_spring_boot_parent",
        "bucket": "breaking"
      },
      {
        "general_idea": "Add JAXB API dependency to replace the module removed from the JDK in Java 11.",
        "why_exists": "JAXB (javax.xml.bind) was removed from the JDK in Java 11; without this explicit dependency, code using JAXB will fail to compile.",
        "before": "",
        "after": "<jaxb.api.version>2.3.0</jaxb.api.version>",
        "kind": "add_jaxb_dependency",
        "bucket": "breaking"
      },
