    "java-app/Dockerfile": [
      {
        "general_idea": "Update the build stage base image from Maven with OpenJDK 8 to Maven with Eclipse Temurin 21.",
        "why_exists": "The application code is migrated to Java 21; building with JDK 8 will fail to compile Java 21 source features or dependencies.",
        "before": "FROM maven:3.8.6-openjdk-8 as builder",
        "after": "FROM maven:3.9.4-eclipse-temurin-21 AS builder",
        "kind": "update_base_image_build",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update the runtime stage base image from OpenJDK 8 JRE Alpine to Eclipse Temurin 21 JRE Alpine.",
        "why_exists": "The application jar is compiled for Java 21; running it on a JDK 8 runtime will result in a NoSuchMethodError or UnsupportedClassVersionError.",
        "before": "FROM openjdk:8-jre-alpine",
        "after": "FROM eclipse-temurin:21-jre-alpine",
        "kind": "update_base_image_runtime",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update the OpenTelemetry Java agent version to a release compatible with Java 21.",
        "why_exists": "Older versions of the OpenTelemetry agent may not support Java 21 bytecode or instrumentation hooks, leading to runtime failures.",
        "before": "RUN wget https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases/download/v1.18.0/opentelemetry-javaagent.jar",
        "after": "RUN wget -q https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases/download/v1.26.0/opentelemetry-javaagent.jar -O /opentelemetry-javaagent.jar",
        "kind": "update_dependency_version",
        "bucket": "breaking"
      }
    ],
    "java-app/pom.xml": [
      {
        "general_idea": "Upgrade Spring Boot parent version from 2.7.5 to 3.5.7 to align with Java 21 and Jakarta EE namespace changes.",
        "why_exists": "Spring Boot 3.x requires Java 17+ and uses Jakarta EE 9+ namespaces (jakarta.* instead of javax.*); using Spring Boot 2.x on Java 21 with Jakarta dependencies causes classpath conflicts and missing symbol errors.",
        "before": "<parent>\n        <groupId>org.springframework.boot</groupId>\n        <artifactId>spring-boot-starter-parent</artifactId>\n        <version>2.7.5</version>",
        "after": "<parent>\n\t\t<groupId>org.springframework.boot</groupId>\n\t\t<artifactId>spring-boot-starter-parent</artifactId>\n\t\t<version>3.5.7</version>",
        "kind": "upgrade_spring_boot_parent",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update Java version property from 1.8 to 21 to target the new JDK.",
        "why_exists": "Spring Boot 3.x requires Java 17+; compiling with Java 8 settings against Spring Boot 3.x libraries results in compilation errors due to missing base classes and language feature incompatibilities.",
        "before": "<java.version>1.8</java.version>",
        "after": "<java.version>21</java.version>",
        "kind": "update_java_version_property",
        "bucket": "breaking"
      },
      {
        "general_idea": "Add maven-compiler-plugin configuration to explicitly set release to 21.",
        "why_exists": "Ensures the compiler targets Java 21 bytecode and API, preventing runtime NoSuchMethodError or UnsupportedClassVersionError on the target JDK.",
        "before": "",
        "after": "<plugin>\n\t\t\t\t<groupId>org.apache.maven.plugins</groupId>\n\t\t\t\t<artifactId>maven-compiler-plugin</artifactId>\n\t\t\t\t<version>3.11.0</version>\n\t\t\t\t<configuration>\n\t\t\t\t\t<release>21</release>\n\t\t\t\t</configuration>\n\t\t\t</plugin>",
        "kind": "add_compiler_plugin_config",
        "bucket": "breaking"
      },
      {
        "general_idea": "Replace javax.validation dependency with Spring Boot starter validation (Jakarta).",
        "why_exists": "The javax.validation API was removed in Java 11 and replaced by Jakarta EE; Spring Boot 3.x uses jakarta.validation, so the old javax dependency causes compile-time symbol not found errors.",
        "before": "<dependency>\n            <groupId>javax.validation</groupId>\n            <artifactId>validation-api</artifactId>\n        </dependency>",
        "after": "<dependency>\n\t\t\t<groupId>org.springframework.boot</groupId>\n\t\t\t<artifactId>spring-boot-starter-validation</artifactId>\n\t\t</dependency>",
        "kind": "migrate_validation_to_jakarta",
        "bucket": "breaking"
      },
      {
        "general_idea": "Remove javax.ws.rs-api dependency as it is no longer compatible with Jakarta EE.",
        "why_exists": "javax.ws.rs is part of the old Java EE namespace; Spring Boot 3.x and Java 21 environments expect Jakarta EE (jakarta.ws.rs) or specific implementations, leading to classpath conflicts or missing symbols if mixed.",
        "before": "<dependency>\n            <groupId>javax.ws.rs</groupId>\n            <artifactId>javax.ws.rs-api</artifactId>\n            <version>2.0</version>\n        </dependency>",
        "after": "",
        "kind": "remove_javax_ws_rs",
