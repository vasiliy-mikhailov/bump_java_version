  "by_file": {
    "backend/pom.xml": [
      {
        "general_idea": "Update the Java version property from 17 to 21 to target the new JDK.",
        "why_exists": "Without this change, the project compiles against Java 17, failing to utilize or enforce Java 21 features and potentially causing runtime incompatibilities if Java 21-specific APIs are used.",
        "before": "<java.version>17</java.version>",
        "after": "<java.version>21</java.version>",
        "kind": "update_java_version",
        "bucket": "breaking"
      },
      {
        "general_idea": "Configure maven-compiler-plugin to include MapStruct processor in annotation processor paths alongside Lombok.",
        "why_exists": "Without this configuration, MapStruct interfaces will not be compiled into implementation classes, leading to compilation errors when the mapper interfaces are used.",
        "before": "<annotationProcessorPaths>\n                        <path>\n                            <groupId>org.projectlombok</groupId>\n                            <artifactId>lombok</artifactId>\n                        </path>\n                    </annotationProcessorPaths>",
        "after": "<annotationProcessorPaths>\n                        <!-- Lombok zuerst -->\n                        <path>\n                            <groupId>org.projectlombok</groupId>\n                            <artifactId>lombok</artifactId>\n                            <version>${lombok.version}</version>\n                        </path>\n\n                        <!-- Dann MapStruct -->\n                        <path>\n                            <groupId>org.mapstruct</groupId>\n                            <artifactId>mapstruct-processor</artifactId>\n                            <version>${mapstruct.version}</version>\n                        </path>\n                    </annotationProcessorPaths>",
        "kind": "configure_annotation_processors",
        "bucket": "breaking"
      }
    ]
  }
