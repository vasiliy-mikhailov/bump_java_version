    "pom.xml": [
      {
        "general_idea": "Update the target Java version property from 1.8 to 21 to align with the JDK 21 migration.",
        "why_exists": "Compilation will fail or produce bytecode incompatible with JDK 21 if the source/target version remains at 1.8.",
        "before": "<java.version>1.8</java.version>",
        "after": "<java.version>21</java.version>",
        "kind": "update_java_version",
        "bucket": "breaking"
      },
      {
        "general_idea": "Add javadoc doclint suppression options to prevent build failures due to strict documentation checks in newer JDKs.",
        "why_exists": "JDK 21 enforces strict doclint checks by default; without suppression, the build fails on minor documentation issues.",
        "before": "",
        "after": "<javadoc.opts>-Xdoclint:none</javadoc.opts>",
        "kind": "add_javadoc_doclint_suppression",
        "bucket": "breaking"
      },
      {
        "general_idea": "Configure maven-javadoc-plugin to use the doclint suppression options defined in properties.",
        "why_exists": "Without passing the -Xdoclint:none flag, the javadoc generation phase fails on JDK 21.",
        "before": "",
        "after": "<additionalparam>${javadoc.opts}</additionalparam>",
        "kind": "configure_javadoc_plugin_doclint",
        "bucket": "breaking"
      },
      {
        "general_idea": "Replace the deprecated Nexus Staging Maven Plugin with the new Central Publishing Maven Plugin for deployment.",
        "why_exists": "The old Nexus Staging plugin is deprecated and may fail or be unsupported for new deployments to Maven Central.",
        "before": "<artifactId>nexus-staging-maven-plugin</artifactId>",
        "after": "<artifactId>central-publishing-maven-plugin</artifactId>",
        "kind": "replace_nexus_plugin",
        "bucket": "breaking"
      },
      {
        "general_idea": "Update wagon-ssh extension version to 3.5.3 to ensure compatibility with modern SSH protocols and JDK 21.",
        "why_exists": "Older wagon versions may fail to connect or handle SSH keys correctly on JDK 21 due to security algorithm changes.",
        "before": "<version>2.10</version>",
        "after": "<version>3.5.3</version>",
        "kind": "update_wagon_ssh_version",
        "bucket": "breaking"
      },
