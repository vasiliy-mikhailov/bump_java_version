        "general_idea": "Upgrade Maven compiler source and target properties from Java 17 to Java 21.",
        "why_exists": "Code using Java 21 features (e.g., virtual threads, pattern matching) will fail to compile with source/target 17.",
        "before": "<maven.compiler.source>17</maven.compiler.source>\n<maven.compiler.target>17</maven.compiler.target>",
        "after": "<maven.compiler.source>21</maven.compiler.source>\n<maven.compiler.target>21</maven.compiler.target>",
        "kind": "update_compiler_target",
        "bucket": "breaking"
      },
      {
        "general_idea": "Add Spring Boot Starter Parent as the project parent to manage dependencies and defaults for Spring Boot 3.x.",
        "why_exists": "Spring Boot 3.x requires Jakarta EE namespaces; without the parent or explicit management, dependency resolution for Spring Boot starters may fail or conflict with older javax dependencies.",
        "before": "",
        "after": "<parent>\n    <groupId>org.springframework.boot</groupId>\n    <artifactId>spring-boot-starter-parent</artifactId>\n    <version>3.1.3</version>\n    <relativePath/>\n</parent>",
        "kind": "add_spring_boot_parent",
        "bucket": "breaking"
      },
      {
        "general_idea": "Replace javax.servlet and javax.persistence dependencies with their Jakarta EE equivalents (jakarta.servlet-api, jakarta.persistence-api).",
        "why_exists": "Spring Boot 3.x runs on Jakarta EE 9+, which moved packages from javax.* to jakarta.*. Code importing javax.servlet or javax.persistence will fail to compile or throw NoClassDefFoundError at runtime.",
        "before": "<dependency>\n    <groupId>javax.servlet</groupId>\n    <artifactId>javax.servlet-api</artifactId>\n    ...\n</dependency>\n<dependency>\n    <groupId>javax.persistence</groupId>\n    <artifactId>javax.persistence-api</artifactId>\n    ...\n</dependency>",
        "after": "<dependency>\n    <groupId>jakarta.servlet</groupId>\n    <artifactId>jakarta.servlet-api</artifactId>\n    <version>6.1.0</version>\n    <scope>provided</scope>\n</dependency>\n<dependency>\n    <groupId>jakarta.persistence</groupId>\n    <artifactId>jakarta.persistence-api</artifactId>\n    <version>3.2.0</version>\n</dependency>",
        "kind": "migrate_javax_to_jakarta",
        "bucket": "breaking"
      },
      {
