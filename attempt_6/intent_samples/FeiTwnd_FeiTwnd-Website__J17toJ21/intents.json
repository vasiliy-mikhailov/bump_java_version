    "Backend/pom.xml": [
      {
        "general_idea": "Update the Java version property from 17 to 21 to align with the target JDK.",
        "why_exists": "Compilation will fail or produce bytecode incompatible with JDK 21 if the source/target version remains at 17.",
        "before": "<java.version>17</java.version>",
        "after": "<java.version>21</java.version>",
        "kind": "update_java_version_property",
        "bucket": "breaking"
      },
      {
        "general_idea": "Add explicit maven compiler source and target properties set to 21.",
        "why_exists": "Ensures the compiler explicitly targets JDK 21 features and bytecode, preventing potential mismatches with the java.version property.",
        "before": "",
        "after": "<maven.compiler.source>21</maven.compiler.source>\n        <maven.compiler.target>21</maven.compiler.target>",
        "kind": "add_compiler_properties",
        "bucket": "polishment"
      },
      {
        "general_idea": "Update maven-compiler-plugin configuration to use the 'release' flag set to 21.",
        "why_exists": "The 'release' flag is the modern standard for cross-compilation and ensures strict adherence to JDK 21 API availability, replacing older source/target flags.",
        "before": "<configuration>\n                    <annotationProcessorPaths>\n                        <path>\n                            <groupId>org.projectlombok</groupId>\n                            <artifactId>lombok</artifactId>\n                        </path>\n                    </annotationProcessorPaths>\n                </configuration>",
        "after": "<configuration>\n                        <release>21</release>\n                        <encoding>UTF-8</encoding>\n                        <annotationProcessorPaths>\n                            <path>\n                                <groupId>org.projectlombok</groupId>\n                                <artifactId>lombok</artifactId>\n                                <version>${lombok}</version>\n                            </path>\n                        </annotationProcessorPaths>\n                    </configuration>",
        "kind": "update_compiler_plugin_release_flag",
        "bucket": "breaking"
      },
