      {
        "general_idea": "Add Jakarta XML Bind API dependency to replace removed Java EE JAXB APIs in JDK 21.",
        "why_exists": "JAXB APIs were removed from the JDK module system in JDK 11 and are not present in JDK 21; code using them will fail with NoClassDefFoundError or compile errors without the explicit dependency.",
        "before": "",
        "after": "<dependency>\n                <groupId>jakarta.xml.bind</groupId>\n                <artifactId>jakarta.xml.bind-api</artifactId>\n                <version>${jakarta.version}</version>\n            </dependency>",
        "kind": "add_jakarta_jaxb_api",
        "bucket": "breaking"
      },
      {
        "general_idea": "Add Jakarta XML Bind implementation dependency (jaxb-impl) to provide runtime support for JAXB.",
        "why_exists": "The API alone is insufficient; the implementation is required at runtime to prevent NoClassDefFoundError when JAXB is used.",
        "before": "",
        "after": "<dependency>\n                <groupId>com.sun.xml.bind</groupId>\n                <artifactId>jaxb-impl</artifactId>\n                <version>4.0.3</version>\n                <scope>runtime</scope>\n            </dependency>",
        "kind": "add_jakarta_jaxb_impl",
        "bucket": "breaking"
      }
